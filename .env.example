# MrWhoOidc environment template
# Copy to .env and adjust for your deployment.

# Required core settings
POSTGRES_PASSWORD=change-me
OIDC_PUBLIC_BASE_URL=https://localhost:8443
CERT_PASSWORD=changeit

# CERT_PASSWORD is required for docker-compose.yml when the container itself serves HTTPS.
# It is not used by docker-compose.tls-termination.yml, which assumes TLS terminates at a reverse proxy.

# For the stock local Docker path, the generated certificate and published ports already match:
#   OIDC_PUBLIC_BASE_URL=https://localhost:8443
#   CERT_PASSWORD=changeit
# You typically only need to change POSTGRES_PASSWORD for a first local run.

# PostgreSQL only applies POSTGRES_PASSWORD when the data directory is first initialized.
# If you reuse an existing local Docker volume and change this value later, startup can fail with:
#   password authentication failed for user "oidc"
# In that case either restore the original password or reset the local state with:
#   docker compose down -v --remove-orphans

# Optional bootstrap token for first-time setup on an empty database.
# Set it before calling POST /bootstrap, then remove it after the first successful bootstrap.
BOOTSTRAP_TOKEN=

# Runtime mode
ASPNETCORE_ENVIRONMENT=Production

# Redis (optional but recommended for production)
REDIS_ENABLED=false
REDIS_CONNECTION_STRING=redis:6379,abortConnect=false

# SMTP / email features
MAIL_ENABLED=false
# Leave MAIL_* empty unless MAIL_ENABLED=true.
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_SMTP_USE_SSL=true
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME=MrWhoOidc
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=

# Logging
LOGGING_LEVEL=Information
LOGGING_LEVEL_ASPNETCORE=Warning

# Reverse proxy / forwarded headers
FORWARDED_HEADERS_ENABLED=true
FORWARDED_HEADERS_REQUIRE_HEADER_SYMMETRY=false
FORWARDED_HEADERS_FORWARD_LIMIT=1
FORWARDED_HEADERS_UNSAFE_TRUST_ALL=false
FORWARDED_HEADERS_ENFORCE_HOST_ALLOW_LIST=false
FORWARDED_HEADERS_ALLOWED_HOST_0=
FORWARDED_HEADERS_ALLOWED_HOST_1=
FORWARDED_HEADERS_ALLOWED_HOST_2=
FORWARDED_HEADERS_KNOWN_PROXY_0=
FORWARDED_HEADERS_KNOWN_PROXY_1=
FORWARDED_HEADERS_KNOWN_PROXY_2=
FORWARDED_HEADERS_KNOWN_NETWORK_0=
FORWARDED_HEADERS_KNOWN_NETWORK_1=

# For TLS termination at a reverse proxy with no local PFX in the backend container:
# - use docker compose -f docker-compose.tls-termination.yml up -d
# - keep OIDC_PUBLIC_BASE_URL on the public https:// URL seen by clients
# - set known proxy or known network values whenever possible
# - do not expose the backend HTTP port directly to the internet

# Notes
# - Multi-tenancy is controlled by the installed platform license.
# - Use docker-compose.production.yml for hardened settings.
# - Use docker-compose.dev.yml for MailHog and development logging.
